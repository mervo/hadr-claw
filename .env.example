# Copy to .env (gitignored) and fill in. No secret value ever goes in a tracked file.

# OpenCode Go / Zen gateway key — https://opencode.ai (subscribe to Go)
OPENCODE_API_KEY=

# OpenAI-compatible gateway base URL
HADR_MODEL_BASE_URL=https://opencode.ai/zen/v1

# Model id on the gateway. deepseek-v4-flash-free works on the free tier with
# tool calls; kimi-k2.7-code is the production candidate (needs balance).
HADR_MODEL=deepseek-v4-flash-free

# Hard caps on the agent loop, enforced in code
HADR_MAX_TURNS=12
HADR_MAX_TOKENS_TOTAL=150000

# Path to a recorded transcript: replays the agent loop with no key (CI/testing)
#HADR_FAKE_MODEL=tests/fixtures/transcripts/morning.json

# Optional: export OTel traces via OTLP (e.g. the compose jaeger profile)
#OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
